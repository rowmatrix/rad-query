# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit API keys.

# LLM backend: openai | anthropic | local
RAD_RAG_LLM_BACKEND=local

# OpenAI (required if backend=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (required if backend=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding model (sentence-transformers model name or OpenAI model)
RAD_RAG_EMBED_MODEL=all-MiniLM-L6-v2

# ChromaDB persistence directory
RAD_RAG_CHROMA_DIR=data/processed/chroma

# ChromaDB collection name
RAD_RAG_COLLECTION=rad_reports
